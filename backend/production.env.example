# Production Environment Configuration
# Copy this to .env on your server laptop

# Database Connection (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://jansaidashaik:admin123@localhost:5432/codegnan_db?schema=public"

# The port where your backend will listen
PORT=4000

# The URL of your frontend (use Tailwind IP of your home/office laptop)
# Example: http://100.64.0.5:3000
FRONTEND_URL="http://YOUR_TAILSCALE_IP:3000"

# Node Environment
NODE_ENV="production"
